{
  "expo": {
    "name": "Check-in scanner",
    "slug": "airline-ticket-scanner",
    "scheme": "airlineticketscanner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#143B57"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ustimweb72.airlineticketscanner",
      "infoPlist": {
        "NSCameraUsageDescription": "$(PRODUCT_NAME) потребує доступу до камери для сканування квитків."
      }
    },
    "android": {
      "icon": "./assets/icon.png",
      "package": "com.ustimweb72.airlineticketscanner",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.5"
          },
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "kotlinVersion": "1.9.25",
            "javaVersion": "17"
          }
        }
      ],
      "expo-sqlite",
      "expo-localization",
      "expo-font",
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "$(PRODUCT_NAME) потребує доступу до камери для сканування квитків.",
          "enableCodeScanner": false,
          "disableFrameProcessors": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "a49898a4-a99b-4dbd-929a-b36054a6b456"
      }
    }
  }
}
