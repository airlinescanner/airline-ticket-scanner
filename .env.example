# API Keys для Airline Ticket Scanner

# Groq API (для розпізнавания квитків через AI - ОБОВ'ЯЗКОВО)
# Отримати: https://console.groq.com/keys
EXPO_PUBLIC_GROQ_API_KEY=your_groq_api_key_here

# Mistral AI API (для аналізу правил реєстрації - ОБОВ'ЯЗКОВО)
# Отримати: https://console.mistral.ai/api-keys/
EXPO_PUBLIC_MISTRAL_API_KEY=your_mistral_api_key_here

# Tavily API (для пошуку інформації про авіакомпанії в інтернеті - ОБОВ'ЯЗКОВО)
# Отримати: https://app.tavily.com/home
EXPO_PUBLIC_TAVILY_API_KEY=your_tavily_api_key_here

# Gemini API (для резервного OCR розпізнавання - ОПЦІОНАЛЬНО)
# Отримати: https://aistudio.google.com/
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Налаштування моделей
EXPO_PUBLIC_MISTRAL_MODEL=mistral-small-latest
EXPO_PUBLIC_GROQ_MODELS=llama-3.3-70b-versatile,llama-3.2-90b-vision-preview

